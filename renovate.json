{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:all-minor-patch"
  ],
  "prConcurrentLimit": 1,
  "prHourlyLimit": 1,
  "labels": ["release:patch"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
