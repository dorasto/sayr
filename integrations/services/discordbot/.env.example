# Sayr API
SAYR_API_KEY=your_sayr_api_key_here

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID

# Database
DATABASE_URL=your_database_url

# Root Domain
VITE_ROOT_DOMAIN=your_root_domain_here

# App API server (used when the Discord bot is hosted separately)
API_SERVER=https://your_api_server_url_here/api/public