{
  "editor.defaultFormatter": "fronterior.biome-monorepo",
  "editor.formatOnSave": true,
  "biome.requireConfiguration": true,

  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },

  // "[typescript]": { "editor.defaultFormatter": "biomejs.biome" },
  // "[typescriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
  // "[javascript]": { "editor.defaultFormatter": "biomejs.biome" },
  // "[javascriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
  // "[json]": { "editor.defaultFormatter": "biomejs.biome" },
  // "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" },

  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/out/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "**/node_modules/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true,
    "**/out/**": true,
    "**/coverage/**": true
  },
  "[typescript]": { "editor.defaultFormatter": "fronterior.biome-monorepo" },
  "[typescriptreact]": {
    "editor.defaultFormatter": "fronterior.biome-monorepo"
  },
  "[javascript]": { "editor.defaultFormatter": "fronterior.biome-monorepo" },
  "[javascriptreact]": {
    "editor.defaultFormatter": "fronterior.biome-monorepo"
  },
  "[json]": { "editor.defaultFormatter": "fronterior.biome-monorepo" },
  "[jsonc]": { "editor.defaultFormatter": "fronterior.biome-monorepo" }
}
