{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"dependsOn": ["^lint:fix"],
			"cache": false
		},
		"format": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true,
			"interactive": true
		},
		"start": {
			"dependsOn": ["build"],
			"cache": false,
			"persistent": true
		}
	},
	"globalDependencies": ["package.json", "pnpm-lock.yaml"],
	"globalEnv": ["NODE_ENV"]
}
