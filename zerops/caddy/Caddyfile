# Caddy reverse proxy config for Zerops
#
# Key design decisions:
#   - Separate named virtual host blocks per domain/subdomain: Caddy expands
#     env-var placeholders in site addresses at startup, so named blocks like
#     {$VITE_ROOT_DOMAIN}:80 correctly win over the bare :80 catch-all.
#   - "dynamic a" upstreams with "versions ipv4": re-resolves DNS on every request.
#     The "versions ipv4" restriction prevents Caddy from attempting IPv6
#     connections, which Zerops internal services do not listen on.
#   - X-Forwarded-Proto hardcoded to "https": Zerops terminates TLS at the L7 balancer
#     and hits this service over plain HTTP. Without this, Better Auth's __Secure-
#     cookie validation would break.
#   - No automatic HTTPS: Zerops handles all TLS/certificate management.

{
	auto_https off
	admin off
}

# ===============================
# HEALTH CHECK
# ===============================
# Separate port to avoid "ambiguous site definition" with the :80 blocks.
# zerops.yml healthCheck.httpGet.port must be 8080.

:8080 {
	handle /healthz {
		respond "ok" 200
	}
	respond 404
}

# ===============================
# ROOT DOMAIN  →  marketing
# ===============================

{$VITE_ROOT_DOMAIN}:80, www.{$VITE_ROOT_DOMAIN}:80 {

	# Redirect /admin/* -> admin subdomain
	handle_path /admin* {
		redir https://admin.{$VITE_ROOT_DOMAIN}{uri} 302
	}

	# Redirect /login -> admin subdomain
	handle /login {
		redir https://admin.{$VITE_ROOT_DOMAIN}/login 302
	}

	# Root API -> backend
	handle /api/* {
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> marketing
	handle {
		reverse_proxy {
			dynamic a marketing 3000 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}

# ===============================
# API SUBDOMAIN  →  backend
# ===============================

api.{$VITE_ROOT_DOMAIN}:80 {

	# /events -> backend /api/events
	handle /events* {
		rewrite * /api/events{path}
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# WebSocket
	handle /ws* {
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
			flush_interval -1
		}
	}

	# Root -> backend /api/public
	handle / {
		rewrite * /api/public
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> /api/public/*
	handle {
		rewrite * /api/public{uri}
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}

# ===============================
# ADMIN SUBDOMAIN  →  start
# ===============================

admin.{$VITE_ROOT_DOMAIN}:80 {

	# Auth API -> start
	handle /api/auth* {
		reverse_proxy {
			dynamic a start 3000 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Image preview -> start
	handle /api/image-preview* {
		reverse_proxy {
			dynamic a start 3000 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Traces -> start
	handle /api/traces* {
		reverse_proxy {
			dynamic a start 3000 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# WebSocket -> backend
	handle /ws* {
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
			flush_interval -1
		}
	}

	# All other API -> backend
	handle /api/* {
		reverse_proxy {
			dynamic a backend 5468 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> start
	handle {
		reverse_proxy {
			dynamic a start 3000 {
				versions ipv4
			}
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}

# ===============================
# WILDCARD CATCH-ALL (org slugs)  →  start
# ===============================
# Named blocks above take priority; this catches all remaining subdomains.

