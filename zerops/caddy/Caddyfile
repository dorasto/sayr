# Caddy reverse proxy config for Zerops
#
# Key design decisions:
#   - "dynamic a" upstreams: Caddy re-resolves DNS on every request, so redeploying
#     start/backend/marketing never requires restarting this service.
#   - X-Forwarded-Proto hardcoded to "https": Zerops terminates TLS at the L7 balancer
#     and hits this service over plain HTTP. Without this, Better Auth's __Secure-
#     cookie validation would break.
#   - X-Forwarded-For is omitted: Caddy sets it automatically by default.
#   - No automatic HTTPS: Zerops handles all TLS/certificate management.
#   - {$VITE_ROOT_DOMAIN} uses Caddy's env var syntax, equivalent to envsubst.
#   - header_up and flush_interval are reverse_proxy subdirectives and must be
#     inlined inside each reverse_proxy block — they cannot live in snippets.

{
	# Disable automatic HTTPS — Zerops L7 balancer handles TLS
	auto_https off
	# Disable the Caddy admin API endpoint (not needed in production)
	admin off
}

# ===============================
# HEALTH CHECK
# ===============================
# Runs on a separate port to avoid Caddy's "ambiguous site definition" error
# when mixing a bare :80 block with named :80 virtual hosts.
# zerops.yml healthCheck.httpGet.port must match this (8080).

:8080 {
	handle /healthz {
		respond "ok" 200
	}
	respond 404
}

# ===============================
# ROOT DOMAIN
# ===============================

{$VITE_ROOT_DOMAIN}:80, www.{$VITE_ROOT_DOMAIN}:80 {

	# Redirect /admin/* -> admin subdomain
	handle_path /admin* {
		redir https://admin.{$VITE_ROOT_DOMAIN}{uri} 302
	}

	# Redirect /login -> admin subdomain
	handle /login {
		redir https://admin.{$VITE_ROOT_DOMAIN}/login 302
	}

	# Root API -> backend
	handle /api/* {
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> marketing
	handle {
		reverse_proxy {
			dynamic a marketing 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}

# ===============================
# API SUBDOMAIN
# ===============================

api.{$VITE_ROOT_DOMAIN}:80 {

	# /events -> backend /api/events
	handle /events* {
		rewrite * /api/events{path}
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# WebSocket -> backend (flush_interval -1 enables streaming/WS passthrough)
	handle /ws* {
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
			flush_interval -1
		}
	}

	# Root -> backend /api/public
	handle / {
		rewrite * /api/public
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> rewrite to /api/public/*
	handle {
		rewrite * /api/public{uri}
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}

# ===============================
# ADMIN SUBDOMAIN
# ===============================

admin.{$VITE_ROOT_DOMAIN}:80 {

	# Auth API -> start
	handle /api/auth* {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Image preview -> start
	handle /api/image-preview* {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Traces -> start
	handle /api/traces* {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Admin WebSocket -> backend (flush_interval -1 enables streaming/WS passthrough)
	handle /ws* {
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
			flush_interval -1
		}
	}

	# All other API -> backend
	handle /api/* {
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> start app
	handle {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}

# ===============================
# WILDCARD SUBDOMAINS (*.domain)
# ===============================
# Catches any subdomain not explicitly matched above (e.g. org slugs).
# Named virtual hosts above take precedence over this wildcard.

*.{$VITE_ROOT_DOMAIN}:80 {

	# Auth API -> start
	handle /api/auth* {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Image preview -> start
	handle /api/image-preview* {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Traces -> start
	handle /api/traces* {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# WebSocket -> backend (flush_interval -1 enables streaming/WS passthrough)
	handle /ws* {
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
			flush_interval -1
		}
	}

	# All other API -> backend
	handle /api/* {
		reverse_proxy {
			dynamic a backend 5468
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}

	# Everything else -> start
	handle {
		reverse_proxy {
			dynamic a start 3000
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto "https"
		}
	}
}
