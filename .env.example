# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
# Runtime environment for the entire application.
# Used by the backend at runtime and injected into the frontend at build time.
# Allowed values: development, production
APP_ENV=development

# Whether this instance is running on the official Sayr Cloud
# Self-hosted installs should leave this as false
SAYR_CLOUD=false


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/sayr


# -----------------------------------------------------------------------------
# Doras (OAuth / Integration)
# -----------------------------------------------------------------------------
DORAS_CLIENT_ID=
DORAS_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Storage (S3-compatible)
# -----------------------------------------------------------------------------
STORAGE_URL=http://localhost:9000
STORAGE_BUCKET=sayr
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# File handling
FILE_SALT=change-me
FILE_CDN=http://localhost:9000/sayr


# -----------------------------------------------------------------------------
# Internal / System
# -----------------------------------------------------------------------------
INTERNAL_SECRET=change-me

# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
# GitHub App (server-to-server)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# GitHub OAuth (user login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email used for system or notifications
SAYR_EMAIL=admin@example.com

# Public-facing GitHub App name (frontend)
VITE_GITHUB_APP_NAME=Sayr


# -----------------------------------------------------------------------------
# Frontend / Public Configuration (VITE_* are exposed)
# -----------------------------------------------------------------------------
VITE_URL_ROOT=http://localhost:3000
VITE_PROJECT_NAME=Sayr
VITE_ROOT_DOMAIN=localhost

# GIF search
VITE_TENOR_API=

# -----------------------------------------------------------------------------
# Observability (Sayr Cloud only)
# -----------------------------------------------------------------------------
AXIOM_OTEL_TOKEN=
AXIOM_OTEL_DATASET=
AXIOM_OTEL_DOMAIN=