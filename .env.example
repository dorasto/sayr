# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
# Runtime environment for the entire application.
# Used by the backend at runtime and injected into the frontend at build time.
# Allowed values: development, production
APP_ENV=development

# Sayr Edition (local development only — Docker images use SAYR_EDITION_BAKED at build time)
# Allowed values: cloud, community, enterprise
# Self-hosted installs should use "community" (the default)
SAYR_EDITION=community

# DEPRECATED: Use SAYR_EDITION instead. Kept for backwards compatibility.
# SAYR_CLOUD=false

# Baked edition for Docker builds (set at image build time, not runtime)
# SAYR_EDITION_BAKED=community


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/sayr


# -----------------------------------------------------------------------------
# Doras (OAuth / Integration)
# -----------------------------------------------------------------------------
DORAS_CLIENT_ID=
DORAS_CLIENT_SECRET=
DORAS_ORGANIZATION=


# -----------------------------------------------------------------------------
# Discord (OAuth)
# -----------------------------------------------------------------------------
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Slack (OAuth)
# -----------------------------------------------------------------------------
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Storage (S3-compatible)
# -----------------------------------------------------------------------------
STORAGE_URL=http://localhost:9000
STORAGE_BUCKET=sayr
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
# STORAGE_REGION=rustfs  # Any non-empty string (required for some S3 providers)


# -----------------------------------------------------------------------------
# File Handling
# -----------------------------------------------------------------------------
FILE_SALT=change-me
# FILE_NAME_HASH_LENGTH=64
FILE_CDN=http://localhost:9000/sayr
# FAVICON_URL=


# -----------------------------------------------------------------------------
# Internal / System
# -----------------------------------------------------------------------------
INTERNAL_SECRET=change-me
# VOTE_SALT=change-me  # For vote/bot detection


# -----------------------------------------------------------------------------
# GitHub Integration
# -----------------------------------------------------------------------------
# GitHub App (server-to-server)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=

# GitHub OAuth (user login)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# GitHub Token (for API access, e.g., marketing site contributors)
# GITHUB_TOKEN=

# Public-facing GitHub App name (frontend)
VITE_GITHUB_APP_NAME=Sayr


# -----------------------------------------------------------------------------
# Email / Notifications
# -----------------------------------------------------------------------------
# Email provider API key (one of: usesend, sendgrid, resend)
# EMAIL_PROVIDER=usesend

# API key for the email provider
# SAYR_EMAIL=

# From address for sent emails
# SAYR_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Polar (Payments / Subscriptions)
# -----------------------------------------------------------------------------
# Polar access token for API calls
# POLAR_ACCESS_TOKEN=
# POLAR_WEBHOOK_SECRET=

# Product ID for subscriptions
# POLAR_PRODUCT_ID=


# -----------------------------------------------------------------------------
# Frontend / Public Configuration (VITE_* are exposed to browser)
# -----------------------------------------------------------------------------
VITE_URL_ROOT=http://admin.app.localhost:3000
VITE_PROJECT_NAME=Sayr
VITE_ROOT_DOMAIN=app.localhost

# Auth callback URL (defaults to VITE_URL_ROOT if not set)
# VITE_AUTH_CALLBACK_URL=

# GIF search API
# VITE_KLIPY_API=

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# PostHog analytics
# VITE_PUBLIC_POSTHOG_KEY=
# VITE_PUBLIC_POSTHOG_HOST=
# POSTHOG_CLI_ENV_ID=
# POSTHOG_CLI_TOKEN=


# -----------------------------------------------------------------------------
# Observability (Sentry)
# -----------------------------------------------------------------------------
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=


# -----------------------------------------------------------------------------
# Observability (Axiom OpenTelemetry)
# -----------------------------------------------------------------------------
# AXIOM_OTEL_TOKEN=
# AXIOM_OTEL_DATASET=
# AXIOM_OTEL_DOMAIN=


# -----------------------------------------------------------------------------
# CAPTCHA (Cap.js - self-hosted proof-of-work)
# -----------------------------------------------------------------------------
# Backend: server-side verification
# CAP_API_ENDPOINT=https://cap.example.com/your-site-key
# CAP_SECRET_KEY=

# Marketing: client-side widget (PUBLIC_ prefix exposes to Astro client)
# PUBLIC_CAP_API_ENDPOINT=https://cap.example.com/your-site-key


# -----------------------------------------------------------------------------
# AI (Mistral)
# -----------------------------------------------------------------------------
# API key for Mistral AI. Required to enable AI features (task summaries, etc.).
# On Sayr Cloud this is managed internally. On Community/Enterprise editions,
# set this key to unlock AI features for your instance.
# MISTRAL_API_KEY=

# -----------------------------------------------------------------------------
# Queue / Worker
# -----------------------------------------------------------------------------
# REDIS_URL=redis://127.0.0.1:6379
