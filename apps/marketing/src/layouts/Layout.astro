---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Sayr - Transparent Project Management",
	description = "Transparent, collaborative project management that bridges internal workflows with public collaboration.",
} = Astro.props;

import { Footer } from "@/components/layout/footer";
import { Navbar } from "@/components/layout/navigationbar";
import "../styles/global.css";
---

<!doctype html>
<script is:inline>
    const getThemePreference = () => {
        if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
        ) {
            return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
    };
    const isDark = getThemePreference() === "dark";
    document.documentElement.classList[isDark ? "add" : "remove"]("dark");

    if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
            const isDark = document.documentElement.classList.contains("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["class"],
        });
    }
</script>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <title>{title}</title>
    </head>
    <body>
        <div class="w-full max-w-6xl mx-auto sticky top-0 z-50">
            <Navbar client:load />
        </div>
        <main class="w-full">
            <slot />
        </main>
        <Footer client:load />
    </body>
</html>
