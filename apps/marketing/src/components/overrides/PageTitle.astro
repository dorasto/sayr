---
/// <reference path="../../env.d.ts" />
/**
 * Custom PageTitle component that displays author and contributors
 * automatically fetched from Git history via route middleware.
 * Also integrates starlight-page-actions for copy/open actions.
 */
import type {
    PageContributors,
    GitContributor,
} from "../../routeData/contributors";
import { createHash } from "node:crypto";
import { Icon } from "@astrojs/starlight/components";
import config from "virtual:starlight-page-actions/config";

// Access route data from Astro.locals
const starlightRoute = Astro.locals.starlightRoute as any;
const entry = starlightRoute?.entry;
const title = entry?.data?.title ?? "Untitled";

// Get contributors from route middleware (populated by contributors.ts)
const pageContributors = starlightRoute?.pageContributors as
    | PageContributors
    | undefined;
const author = pageContributors?.author;
const contributors = pageContributors?.contributors ?? [];

// Get last updated date from Starlight route data
const lastUpdated = starlightRoute?.lastUpdated as Date | undefined;

// Page actions setup
interface OptionsProps {
    label: string;
    href: string;
    id: "chatgpt" | "claude" | "markdown" | "v0" | "t3chat";
}

const currentPath = Astro.url.pathname.replace(/\/$/, "");
const currentUrl = Astro.url.href;
const { actions, prompt: userPrompt } = config;
const { pageActions } = entry?.data ?? {};

const prompt = userPrompt?.includes("{url}")
    ? userPrompt?.replace("{url}", currentUrl)
    : `${userPrompt} ${currentUrl}`;
const encodedPrompt = encodeURIComponent(prompt as string);

const defaultOptions: OptionsProps[] = [
    {
        label: (Astro.locals as any).t("open.chatgpt"),
        href: `https://chatgpt.com/?q=${encodedPrompt}`,
        id: "chatgpt",
    },
    {
        label: (Astro.locals as any).t("open.claude"),
        href: `https://claude.ai/new?q=${encodedPrompt}`,
        id: "claude",
    },
    {
        label: (Astro.locals as any).t("open.t3chat"),
        href: `https://t3.chat/new?q=${encodedPrompt}`,
        id: "t3chat",
    },
    {
        label: (Astro.locals as any).t("open.v0"),
        href: `https://v0.app/?q=${encodedPrompt}`,
        id: "v0",
    },
    {
        label: (Astro.locals as any).t("view.markdown"),
        href: `${currentPath}.md`,
        id: "markdown",
    },
];

const filteredDefaultOptions = defaultOptions.filter((option) => {
    const id = option.id;
    if (actions && actions[id]) {
        return option;
    }
    return;
});

type CustomAction = { label: string; href: string };
const customEntries = actions?.custom
    ? (Object.entries(actions.custom) as [string, CustomAction][])
    : [];
const customOptions: OptionsProps[] = customEntries.map(([key, value]) => ({
    label: value.label,
    href: `${value.href}${encodedPrompt}`,
    id: key as OptionsProps["id"],
}));

const options = [...filteredDefaultOptions, ...customOptions];
const showPageActions = pageActions || typeof pageActions === "undefined";

// Helper to get MD5 hash for Gravatar
function md5(str: string): string {
    return createHash("md5").update(str.trim().toLowerCase()).digest("hex");
}

// Helper to get avatar URL - GitHub if available, otherwise Gravatar
function getAvatarUrl(person: GitContributor): string {
    if (person.github) {
        return `https://github.com/${person.github}.png?size=48`;
    }
    // Fallback to Gravatar using email hash
    const hash = md5(person.email);
    return `https://www.gravatar.com/avatar/${hash}?s=48&d=identicon`;
}

// Helper to get display name
function getDisplayName(person: GitContributor): string {
    return person.name;
}

// Helper to get profile URL
function getProfileUrl(person: GitContributor): string | null {
    if (person.github) {
        return `https://github.com/${person.github}`;
    }
    return null;
}
---

<h1
    id="_top"
    class="text-(length:--sl-text-h1) font-semibold leading-(--sl-line-height-headings) text-(--sl-color-white) flex-auto min-w-0"
>
    {title}
</h1>

{
    (author || contributors.length > 0 || lastUpdated || showPageActions) && (
        <div
            id="page-meta"
            class="flex flex-wrap items-center gap-6 my-0 py-3 text-sm"
        >
            {author && (
                <div class="flex items-center gap-1.5">
                    <div class="flex items-center gap-2">
                        <img
                            src={getAvatarUrl(author)}
                            alt={getDisplayName(author)}
                            class="rounded-full border border-(--sl-color-gray-5)"
                            width="24"
                            height="24"
                        />
                        {getProfileUrl(author) ? (
                            <a
                                href={getProfileUrl(author)!}
                                class="text-(--sl-color-text-accent) no-underline hover:underline"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                {getDisplayName(author)}
                            </a>
                        ) : (
                            <span class="text-(--sl-color-white)">
                                {getDisplayName(author)}
                            </span>
                        )}
                    </div>
                </div>
            )}

            {lastUpdated && (
                <div class="flex flex-col gap-1.5">
                    <span class="text-xs tracking-wide">
                        Updated on{" "}
                        <time
                            datetime={lastUpdated.toISOString()}
                            class="text-(--sl-color-white)"
                        >
                            {lastUpdated.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })}
                        </time>
                    </span>
                </div>
            )}

            {contributors.length > 0 && (
                <div class="flex flex-col gap-1.5">
                    <span class="text-(--sl-color-gray-3) text-xs uppercase tracking-wide">
                        Contributors
                    </span>
                    <div class="flex flex-row-reverse justify-end">
                        {contributors.map((contributor) => {
                            const profileUrl = getProfileUrl(contributor);
                            const avatar = (
                                <img
                                    src={getAvatarUrl(contributor)}
                                    alt={getDisplayName(contributor)}
                                    class="rounded-full border-2 border-(--sl-color-bg) shadow-[0_0_0_1px_var(--sl-color-gray-5)] block"
                                    width="28"
                                    height="28"
                                    title={getDisplayName(contributor)}
                                />
                            );
                            return profileUrl ? (
                                <a
                                    href={profileUrl}
                                    class="-ml-2 first:ml-0 transition-transform duration-150 hover:-translate-y-0.5 hover:z-10"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    {avatar}
                                </a>
                            ) : (
                                <span class="-ml-2 first:ml-0 transition-transform duration-150 hover:-translate-y-0.5 hover:z-10">
                                    {avatar}
                                </span>
                            );
                        })}
                    </div>
                </div>
            )}

            {showPageActions && (
                <div class="actions-container flex gap-2 ml-auto">
                    <button
                        class="action-button"
                        id="copy-markdown"
                        data-path={currentPath}
                    >
                        <Icon name="mdx" size="1rem" class="icon-default" />
                        <Icon
                            name="approve-check"
                            size="1rem"
                            class="icon-success"
                        />
                        <Icon name="error" size="1rem" class="icon-error" />
                        <span>{(Astro.locals as any).t("copy.markdown")}</span>
                    </button>

                    {options.length !== 0 && (
                        <div class="dropdown relative">
                            <button
                                class="action-button"
                                id="dropdown-toggle"
                                aria-label="More options"
                            >
                                <span>{(Astro.locals as any).t("open")}</span>
                                <Icon name="down-caret" size="1rem" />
                            </button>

                            <div id="dropdown-menu">
                                {options.map((option) => (
                                    <a
                                        href={option.href}
                                        class="dropdown-item"
                                        target="_blank"
                                    >
                                        <span>{option.label}</span>
                                        <Icon
                                            name="external"
                                            size="1rem"
                                            class="external-icon"
                                        />
                                    </a>
                                ))}
                            </div>
                        </div>
                    )}
                </div>
            )}
        </div>
    )
}

<style>
    .action-button {
        background-color: var(--sl-color-gray-6);
        color: var(--sl-color-white);
        border: 1px solid var(--sl-color-gray-5);
        padding: 0.5rem 0.75rem;
        border-radius: 0.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        font-family: var(--sl-font);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: opacity 0.2s ease;
        height: 2rem;
        line-height: 1;
    }

    #copy-markdown:disabled {
        opacity: 0.7;
    }

    .icon-success,
    .icon-error {
        display: none;
    }

    #copy-markdown.copied .icon-default,
    #copy-markdown.error .icon-default {
        display: none;
    }

    #copy-markdown.copied .icon-success,
    #copy-markdown.error .icon-error {
        display: block;
    }

    #dropdown-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        right: 0;
        background-color: var(--sl-color-gray-6);
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.25rem;
        padding: 0.25rem;
        min-width: 200px;
        box-shadow:
            0 4px 6px -1px rgba(0, 0, 0, 0.3),
            0 2px 4px -1px rgba(0, 0, 0, 0.2);
        display: none;
        z-index: 10;
    }

    #dropdown-menu.show {
        display: block;
    }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        color: var(--sl-color-white);
        text-decoration: none;
        border-radius: 0.25rem;
        font-size: 0.875rem;
        transition: background-color 0.15s ease;
        cursor: pointer;
        width: 100%;
    }

    .dropdown-item:hover {
        background-color: var(--sl-color-gray-5);
    }

    .dropdown-item span {
        flex: 1;
    }

    .dropdown-item .external-icon {
        margin-left: auto;
    }
</style>

<script>
    const copyButton = document.querySelector(
        "#copy-markdown",
    ) as HTMLButtonElement;
    let copyButtonClass: "copied" | "error" = "copied";

    copyButton?.addEventListener("click", async () => {
        try {
            copyButton.disabled = true;

            const currentPath = copyButton.dataset.path;
            const mdPath = `${currentPath}.md`;

            const res = await fetch(mdPath);
            const contentForClipboard = await res.text();

            await navigator.clipboard.writeText(contentForClipboard);
        } catch (error) {
            console.error(error);
            copyButtonClass = "error";
        } finally {
            copyButton.classList.add(copyButtonClass);
            copyButton.disabled = false;

            setTimeout(() => {
                copyButton.classList.remove(copyButtonClass);
            }, 3000);
        }
    });

    const dropdownToggle = document.querySelector(
        "#dropdown-toggle",
    ) as HTMLButtonElement;
    const dropdownMenu = document.querySelector(
        "#dropdown-menu",
    ) as HTMLElement;

    dropdownToggle?.addEventListener("click", (e) => {
        e.stopPropagation();
        dropdownMenu.classList.toggle("show");
    });

    document.addEventListener("click", () => {
        dropdownMenu?.classList.remove("show");
    });

    dropdownMenu?.addEventListener("click", (e) => {
        e.stopPropagation();
    });
</script>
