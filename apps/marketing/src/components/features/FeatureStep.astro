---
interface Props {
   number: string;
   title: string;
   description: string;
}

const { number, title, description } = Astro.props;
---

<div class="not-prose flex gap-4 py-4">
   <div class="shrink-0 size-10 rounded-xl bg-primary/10 flex items-center justify-center">
      <span class="text-sm font-bold text-primary font-mono">{number}</span>
   </div>
   <div class="pt-1.5">
      <h4 class="text-base font-semibold mb-1">{title}</h4>
      <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>
   </div>
</div>
