---
import { getFeature } from "@/data/features";

interface Props {
    slugs: string[];
}

const { slugs } = Astro.props;

const related = slugs.map((slug) => getFeature(slug)).filter(Boolean);
---

{
    related.length > 0 && (
        <div class="not-prose mt-16 pt-10">
            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-6">
                Related Features
            </p>
            <div class="grid sm:grid-cols-3 gap-4">
                {related.map((feature) => (
                    <a
                        href={`/features/${feature?.slug}`}
                        class="group rounded-xl border border-border bg-card hover:border-primary/30 hover:bg-primary/[0.02] transition-colors p-4 block"
                    >
                        <p class="text-sm font-semibold mb-1 group-hover:text-primary transition-colors">
                            {feature?.title}
                        </p>
                        <p class="text-xs text-muted-foreground leading-relaxed">
                            {feature?.navDesc}
                        </p>
                    </a>
                ))}
            </div>
        </div>
    )
}
