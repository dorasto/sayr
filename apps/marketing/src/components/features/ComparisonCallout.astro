---
interface Props {
   competitor: string;
   sayrDoes: string;
   theyDont?: string;
}

const { competitor, sayrDoes, theyDont } = Astro.props;
---

<div class="not-prose my-8 rounded-2xl border border-border bg-card overflow-hidden">
   <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-border">
      <div class="p-5 flex gap-3">
         <div class="mt-0.5 size-5 rounded-full bg-destructive/10 flex items-center justify-center shrink-0">
            <svg class="size-3 text-destructive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
         </div>
         <div>
            <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">{competitor}</p>
            <p class="text-sm text-muted-foreground">{theyDont ?? "Doesn't have this"}</p>
         </div>
      </div>
      <div class="p-5 flex gap-3 bg-primary/[0.03]">
         <div class="mt-0.5 size-5 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
            <svg class="size-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
         </div>
         <div>
            <p class="text-xs font-semibold text-primary/70 uppercase tracking-wide mb-1">Sayr</p>
            <p class="text-sm">{sayrDoes}</p>
         </div>
      </div>
   </div>
</div>
