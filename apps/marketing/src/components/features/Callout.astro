---
interface Props {
   label: string;
   description?: string;
}

const { label, description } = Astro.props;
---

<div class="not-prose my-8 rounded-2xl border border-primary/20 bg-primary/[0.03] p-6">
   <p class="text-xs font-semibold text-primary uppercase tracking-wide mb-2">{label}</p>
   {description && <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>}
   <slot />
</div>
