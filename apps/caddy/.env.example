# =============================================================================
# Caddy Proxy Manager Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# Your root domain
ROOT_DOMAIN=sayr.dev

# IP address or hostname of the server running the Sayr app stack (Coolify)
UPSTREAM_HOST=

# Email for Let's Encrypt certificate registration
ACME_EMAIL=

# Cloudflare API token with Zone:DNS:Edit permission for your domain
# Create one at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Service ports on the upstream server (defaults shown, override if needed)
# START_PORT=3000
# BACKEND_PORT=5468
# MARKETING_PORT=8080
