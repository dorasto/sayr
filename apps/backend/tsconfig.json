{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"paths": {
			"@/routes/*": ["./routes/*"],
			"@/public/*": ["./public/*"],
			"@/index": ["./index.ts"],
			"@/queue": ["./queue.ts"],
			"@/util": ["./util.ts"],
			"@/getSession": ["./getSession.ts"],
			"@/tracing/*": ["./tracing/*.ts"],
			"@/prosekit/*": ["./prosekit/*.ts"]
		}
	},
	"include": [
		"routes",
		"public",
		"index.ts",
		"queue.ts",
		"github",
		"responses.ts",
		"openapi",
		"prosekit"
	],
	"exclude": ["node_modules"]
}
